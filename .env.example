# Feishu
FEISHU_WEBHOOK_URL=

# Scheduler
DB_PATH=./data/monitor.db
LOOP_INTERVAL_SECONDS=30
DEFAULT_POLL_SECONDS=300
TIMEOUT_HOURS=72
TIMEOUT_POLL_SECONDS=7200
TIMEOUT_FOLLOWUP_DAYS=7

# Chrome Web Store API
CHROME_PUBLISHER_ID=
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=
# Optional: direct token if you don't want refresh flow
CHROME_ACCESS_TOKEN=

# Edge Add-ons API (optional; preferred when operation_id exists)
EDGE_CLIENT_ID=
EDGE_API_KEY=

# Edge review email fallback (optional)
EDGE_IMAP_HOST=
EDGE_IMAP_PORT=993
EDGE_IMAP_USER=
EDGE_IMAP_PASS=
EDGE_IMAP_FOLDER=INBOX
EDGE_IMAP_FOLDERS=INBOX,[Gmail]/All Mail
EDGE_IMAP_SCAN_LIMIT=300
EDGE_MAIL_FROM_KEYWORDS=microsoftedge,microsoft
EDGE_MAIL_APPROVED_KEYWORDS=approved,published,success
EDGE_MAIL_REJECTED_KEYWORDS=rejected,failed,denied
EDGE_MAIL_ACTION_KEYWORDS=action required,needs attention
# optional aliases for name matching (format: item_id:alias1|alias2;item_id2:alias3)
EDGE_MAIL_NAME_ALIASES=
# proactive alert when edge email matching stays empty for too long
EDGE_NO_MATCH_ALERT_HOURS=24
EDGE_NO_MATCH_ALERT_REPEAT_HOURS=24

# Feishu command bot (event callback)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=
FEISHU_STATUS_HOST=0.0.0.0
FEISHU_STATUS_PORT=8088
FEISHU_STATUS_COMMAND=status
# format: store:item_id;store:item_id;...
FEISHU_STATUS_PLUGIN_TARGETS=chrome:glcbkndciojfeepepdoeofgpojigcdmf;chrome:pmblmkemjdeicgahfkiogdkhjhefhhea;edge:bgfbcbkjjndjeamckkakgkiphdhlmbip;edge:eboeciamjbjeobdhnikpddmpnijicmhg
